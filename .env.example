# =============================================================================
# VentureForge - Environment Configuration
# =============================================================================
# Copy this to .env.local and fill in your values.
# Items marked [FREE] need no API key - they work out of the box.
# =============================================================================

# --- DATABASE (Required) ---
# Get a free PostgreSQL database at:
#   https://neon.tech (free tier)
#   https://supabase.com (free tier)
#   https://railway.app (free tier)
DATABASE_URL="postgresql://user:password@localhost:5432/ventureforge"

# --- AUTHENTICATION (Required) ---
# Generate with: openssl rand -base64 32
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="CHANGE_ME_generate_with_openssl_rand_base64_32"

# --- AI ---
# Option 1: Use OpenAI GPT-4o (requires API key)
# Get key at: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-key-here"

# Option 2: Use local Ollama (free, no key needed)
# 1. Install: https://ollama.com
# 2. Pull a model: ollama pull llama3.2:3b
# 3. Run: ollama serve
# 4. Set model name (default: llama3.2:3b)
OLLAMA_MODEL="llama3.2:3b"

# --- ECONOMIC DATA APIS (All FREE, no key needed) ---
# World Bank API - https://api.worldbank.org/v2/ (FREE)
# IMF Data API - https://www.imf.org/external/datamapper (FREE)
# Census Bureau - https://api.census.gov (FREE)

# --- FRED API (FREE with registration) ---
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY="your-fred-api-key"

# --- STRIPE (Optional - for payments) ---
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_your-stripe-secret"
STRIPE_PUBLISHABLE_KEY="pk_test_your-stripe-publishable"
STRIPE_WEBHOOK_SECRET="whsec_your-webhook-secret"

# --- EMAIL (Optional - for notifications) ---
# Get key at: https://resend.com/api-keys
RESEND_API_KEY="re_your-resend-key"
EMAIL_FROM="VentureForge <noreply@yourdomain.com>

# --- BLOCKCHAIN VERIFICATION ---
# Optional: Use a real blockchain for plan certification
# Algorand: https://developer.algorand.org
ALGORAND_API_URL="https://testnet-api.algonode.cloud"
ALGORAND_API_TOKEN="your-algorand-token"

# --- ENCRYPTION ---
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY="CHANGE_ME_generate_with_openssl_rand_hex_32"
