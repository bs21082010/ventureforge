# =============================================================================
# VentureForge — Production Environment Variables (for Vercel)
# =============================================================================
# Copy this to your Vercel project's Environment Variables or rename to .env.local
# for local testing with PostgreSQL.
# =============================================================================

# --- DATABASE ---
# Production: Use PostgreSQL (Neon, Vercel Postgres, Supabase, etc.)
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL="postgresql://postgres:password@localhost:5432/ventureforge?sslmode=require"

# --- AUTH ---
# Replace with the URL of your deployed app (no trailing slash)
NEXTAUTH_URL="https://ventureforge.vercel.app"
# Generate a strong random secret: openssl rand -base64 32
NEXTAUTH_SECRET="generate-a-strong-random-secret-at-least-32-chars"

# --- AI ---
# Get your OpenAI API key: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-key-here"

# --- DATA SOURCES ---
# FRED API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY="your-fred-api-key"

# --- ENCRYPTION ---
# 64 hex characters (32 bytes) for AES-256-GCM
ENCRYPTION_KEY="a1b2c3d4e5f6a7b8c9d0e1f2a3b4c5d6e7f8a9b0c1d2e3f4a5b6c7d8e9f0a1b2"

# --- STRIPE (not available in India - all features are free) ---
# If Stripe becomes available, uncomment and set keys:
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_PUBLISHABLE_KEY="pk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
